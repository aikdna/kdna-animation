{
  "name": "animation_kdna_cluster",
  "version": "0.2.0",
  "purpose": "Open-source KDNA cluster for animation, motion design, GSAP, Motion Canvas, frontend motion systems, AI animation workflows, and review judgment.",
  "packages": [
    {
      "id": "motion_design_master",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    },
    {
      "id": "gsap_master",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    },
    {
      "id": "motion_canvas_master",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    },
    {
      "id": "web_animation_performance",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    },
    {
      "id": "frontend_motion_system",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    },
    {
      "id": "ai_animation_workflow",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    },
    {
      "id": "animation_review_master",
      "role": "primary",
      "use_when": [
        "Task matches domain scope"
      ]
    }
  ],
  "composition_rules": [
    {
      "task": "web_interaction_motion",
      "load": [
        "motion_design_master",
        "gsap_master",
        "web_animation_performance",
        "frontend_motion_system"
      ]
    },
    {
      "task": "programmatic_video_explainer",
      "load": [
        "motion_design_master",
        "motion_canvas_master",
        "animation_review_master"
      ]
    },
    {
      "task": "agent_generated_animation",
      "load": [
        "ai_animation_workflow",
        "motion_design_master",
        "animation_review_master"
      ]
    },
    {
      "task": "quality_review",
      "load": [
        "animation_review_master",
        "motion_design_master",
        "web_animation_performance"
      ]
    }
  ],
  "routing_questions": [
    "accessibility and performance override decorative ambition",
    "attention path overrides effect novelty",
    "domain-specific implementation guidance overrides generic motion taste",
    "when uncertain, reduce simultaneous motion and increase clarity"
  ]
}
